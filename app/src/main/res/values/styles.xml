<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextStyle.Tritery.bold" parent="TextAppearance.AppCompat">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">32sp</item>
        <item name="fontFamily">@font/font</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextStyle.Tritery.light" parent="TextAppearance.AppCompat">
        <item name="android:textStyle">normal</item>
        <item name="android:textSize">20sp</item>
        <item name="fontFamily">@font/font</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextStyle.secondary.normal" parent="TextAppearance.AppCompat">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">12sp</item>
        <item name="fontFamily">@font/font</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="TextStyle.secondary.bold" parent="TextAppearance.AppCompat">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">12sp</item>
        <item name="fontFamily">@font/font</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="TextStyle.primary.normal" parent="TextAppearance.AppCompat">
        <item name="android:textStyle">normal</item>
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">@font/font</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="TextStyle.primary.bold" parent="TextAppearance.AppCompat">
        <item name="android:textStyle">normal</item>
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">@font/font</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="TextStyle.primary.normal12" parent="TextAppearance.AppCompat">
        <item name="android:textStyle">normal</item>
        <item name="android:textSize">12sp</item>
        <item name="fontFamily">@font/font</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="Widget.Pixlog.AppWidget.Container" parent="android:Widget">
        <item name="android:id">@android:id/background</item>
        <item name="android:background">?android:attr/colorBackground</item>
    </style>

    <style name="Widget.Pixlog.AppWidget.InnerView" parent="android:Widget">
        <item name="android:background">?android:attr/colorBackground</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>
</resources>